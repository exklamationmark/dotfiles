# terminator config
mkdir -p ~/.config/terminator
cp -f ~/.temp/dotfiles/.terminator_config ~/.config/terminator/config

# coding environment
if [[ -d "~/workspace" ]]
then
	mkdir ~/workspace
fi

#--------------------------------------------------------------------------------------------------
# go
install golang apt
# gopath
echo "export GOPATH='~/workspace'
REPOS=\$(find ~/workspace -maxdepth 1 -mindepth 1 -type d -printf '%f ')
for dir in \$REPOS
do
	export GOPATH=\$GOPATH:~/workspace/\$dir
	export PATH=\$PATH:~/workspace/\$dir/bin
done" >> ~/.bashrc
source ~/.bashrc

# hipchat
if ( ! is_installed hipchat )
then
	sudo echo "deb http://downloads.hipchat.com/linux/apt stable main" > /etc/apt/sources.list.d/atlassian-hipchat.list
	sudo wget -O - https://www.hipchat.com/keys/hipchat-linux.key | sudo apt-key add -
	sudo apt-get update
fi
install hipchat apt

# postgresql
