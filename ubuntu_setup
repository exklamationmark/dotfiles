#!/bin/bash
. setup_functions

# temp folder
rm -rf ~/.temp
mkdir -p ~/.temp








# essential 
install git apt
install curl apt
install vim apt

# browsers
install libxss1 apt
install google-chrome-stable deb "https://dl.google.com/linux/direct/google-chrome-stable_current_amd64.deb"

# version control
install gitk apt
install kdiff3 apt

# bash config
git clone https://github.com/exklamationmark/dotfiles.git ~/.temp/dotfiles
cp -f ~/.temp/dotfiles/.bashrc ~/.bashrc
cp -f ~/.temp/dotfiles/.bash_aliases ~/.bash_aliases
source ~/.bashrc

# git config
cp -f ~/.temp/dotfiles/.gitconfig ~/.gitconfig

# show branch name in git repo
cat ~/.temp/dotfiles/.custom_prompt >> ~/.bashrc

# git alias
echo "alias gitka='gitk --all'" >> ~/.bash_aliases

# minimum .vimrc
cp -f ~/.temp/dotfiles/.vimrc ~/.vimrc

# vim's plugin: pathogen
rm -rf ~/.vim
mkdir -p ~/.vim/autoload ~/.vim/bundle
curl -Sso ~/.vim/autoload/pathogen.vim https://raw.github.com/tpope/vim-pathogen/master/autoload/pathogen.vim
echo "execute pathogen#infect()" >> ~/.vimrc

# use solarized theme in vim
git clone git://github.com/altercation/vim-colors-solarized.git ~/.vim/bundle/vim-colors-solarized
echo "syntax enable
set background=dark
colorscheme solarized" >> ~/.vimrc
echo "export TERM=screen-256color" >> ~/.bashrc

# user solarized gnome (terminal) 
git clone git://github.com/sigurdga/gnome-terminal-colors-solarized.git ~/.temp/gnome-terminal-colors-solarized
sh ~/.temp/gnome-terminal-colors-solarized/set_dark.sh

# terminator terminal (multiple windows)
#install terminator apt
# terminator config
#mkdir -p ~/.config/terminator
#cp -f ~/.temp/dotfiles/.terminator_config ~/.config/terminator/config

# tmux
install tmux apt

# coding environment
if [[ -d "~/workspace" ]]
then
	mkdir ~/workspace
fi

#--------------------------------------------------------------------------------------------------
# go
install golang apt
# gopath
echo "export GOPATH='$HOME/workspace'" >> ~/.bashrc
echo "export PATH=\$PATH:\$GOPATH/bin" >> ~/.bashrc
mkdir -p ~/workspace/bin
mkdir -p ~/workspace/pkg
mkdir -p ~/workspace/src
source ~/.bashrc

# postgresql
install postgresql-9.1 apt
install postgresql-server-dev-9.1 apt

# rvm with ruby
if [[ ! -d ~/.rvm ]]
then
	\curl -sSL https://get.rvm.io | bash -s stable --ruby
else
	echo -e $COLOR_GREEN"RVM is already installed"$COLOR_NONE
	echo "source ~/.rvm/scripts/rvm" >> ~/.bashrc #since what RVM put there was lost when ubuntu_setup is run twice
	source ~/.bashrc
fi

# nodejs
install nodejs apt

