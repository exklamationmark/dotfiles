#!/bin/bash
. setup_functions

# temp folder
rm -rf ~/.temp
mkdir -p ~/.temp

############################# Qualcomm Atheros Ethernet #############################
# if the motherboard is using this (which is not recognized by Ubuntu right away)
# sudo apt-get install git dkms build-essential linux-headers-generic
# sudo dkms add ./atheros_ethernet
# sudo dkms build atheros_ethernet/2.0
# sudo dkms install atheros_ethernet/2.0

pause "Select a fast, local mirror, then press [Enter]..."

# # update apt repos
# sudo apt-get update

############################# setup workstation #############################

# essential 
pause "Instaling essential packages. Press [Enter] to continue..."

install_linux apt git
install_linux apt mercurial
install_linux apt curl
install_linux apt vim
install_linux apt python-software-properties
install_linux apt python3-pip
install_linux apt openssh-server
install_linux apt gitk
install_linux apt kdiff3
install_linux apt meld
install_linux apt tmux


# # browsers
# install_linux libxss1:amd64 apt
# install_linux google-chrome-stable deb "https://dl.google.com/linux/direct/google-chrome-stable_current_amd64.deb"

# # sublime
# install_linux deb sublime "http://c758482.r82.cf2.rackcdn.com/sublime-text_build-3083_amd64.deb"

############################# customize tools #############################

pause "Configuring tools & scripts. Press [Enter] to continue..."

# bash config
git clone git://github.com/exklamationmark/dotfiles.git ~/.temp/dotfiles
cp -f ~/.temp/dotfiles/.bashrc ~/.bashrc
cp -f ~/.temp/dotfiles/.bash_aliases ~/.bash_aliases

# show branch name in git repo
cat ~/.temp/dotfiles/.bash_custom_prompt >> ~/.bashrc

# custom routing for vpn traffic
cp -f ~/.temp/dotfiles/happyvpn ~/.ssh/happyvpn

# git config
cp -f ~/.temp/dotfiles/.gitconfig ~/.gitconfig

# minimum .vimrc
cp -f ~/.temp/dotfiles/.vimrc ~/.vimrc

# use solarized theme in vim
git clone git://github.com/altercation/vim-colors-solarized.git ~/.temp/vim-colors-solarized
cp -rf ~/.temp/vim-colors-solarized/colors/solarized.vim ~/.vim/colors/

# user solarized gnome (terminal)
git clone git://github.com/Anthony25/gnome-terminal-colors-solarized.git ~/.temp/gnome-terminal-colors-solarized
~/.temp/gnome-terminal-colors-solarized/set_dark.sh

# coding environment
if [[ -d "~/workspace" ]]
then
	mkdir ~/workspace
fi



############################# work-stuff #############################

# ----------------------------- go (1.4.2) -----------------------------
sudo rm -rf /usr/local/go
curl 'https://storage.googleapis.com/golang/go1.4.2.linux-amd64.tar.gz' > ~/.temp/golang.tar.gz
sudo tar -C /usr/local/ -xzvf ~/.temp/golang.tar.gz
sudo ln -sf /usr/local/go/bin/go /usr/local/bin/go

go get github.com/tools/godep # dependency management
go get github.com/golang/lint/golint

mkdir -p ~/workspace/bin
mkdir -p ~/workspace/pkg
mkdir -p ~/workspace/src
source ~/.bashrc

# vim-related
git clone git://github.com/fatih/vim-go ~/.temp/vim-go
mkdir -p $HOME/.vim/autoload/go
cp -rf ~/.temp/vim-go/ftdetect ~/.vim/ftdetect
cp -rf ~/.temp/vim-go/ftplugin ~/.vim/ftplugin
cp -rf ~/.temp/vim-go/syntax ~/.vim/syntax
cp -f ~/.temp/vim-go/autoload/go/complete.vim ~/.vim/autoload/go/complete.vim

# ----------------------------- docker -----------------------------
install_linux apt docker.io
USER=`whoami`
sudo usermod -aG docker $USER
sudo ln -sf /usr/bin/docker.io /usr/local/bin/docker

# vim-related
git clone git://github.com/ekalinin/Dockerfile.vim.git ~/.temp/Dockerfile.vim
cp -rf ~/.temp/Dockerfile.vim/ftdetect ~/.vim/ftdetect
cp -rf ~/.temp/Dockerfile.vim/syntax ~/.vim/syntax

# docker login
cp -f ~/.temp/dotfiles/.dockercfg ~/.dockercfg

# ----------------------------- postgresql -----------------------------
# echo "deb http://apt.postgresql.org/pub/repos/apt/ trusty-pgdg main install_linux apt postgresql-9.4" > \
#       sudo /etc/apt/sources.list.d/pgdg.list
# wget -O - https://www.postgresql.org/media/keys/ACCC4CF8.asc | sudo apt-key add -
# sudo apt-get update
install_linux apt postgresql-server-dev-9.4
 
# ----------------------------- postgresql -----------------------------
install_linux apt redis-server apt

# ----------------------------- rabbitmq -----------------------------
install_linux apt rabbitmq-server apt
sudo rabbitmq-plugins enable rabbitmq_management
sudo service rabbitmq-server restart

# ----------------------------- ruby -----------------------------
# if [[ ! -d ~/.rvm ]]
# then
# 	\curl -sSL https://get.rvm.io | bash -s stable --ruby
# else
# 	echo -e $COLOR_GREEN"RVM is already installed"$COLOR_NONE
# 	echo "source ~/.rvm/scripts/rvm" >> ~/.bashrc #since what RVM put there was lost when ubuntu_setup is run twice
# 	source ~/.bashrc
# fi
# # progress bar for gem download
# echo progress-bar >> ~/.curlrc
# echo "gem: --no-rdoc --no-ri " >> ~/.gemrc
