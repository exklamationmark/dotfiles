#!/bin/bash
. setup_functions

############################# Qualcomm Atheros Ethernet #############################
# if the motherboard is using this (which is not recognized by Ubuntu right away)
# sudo apt-get install git dkms build-essential linux-headers-generic
# sudo dkms add ./atheros_ethernet
# sudo dkms build atheros_ethernet/2.0
# sudo dkms install atheros_ethernet/2.0

pause "Select a fast, local mirror, then press [Enter]..."

# # update apt repos
# sudo apt-get update

############################# setup workstation #############################

# essential
pause "Instaling essential packages. Press [Enter] to continue..."

install_linux apt git
install_linux apt mercurial
install_linux apt curl
install_linux apt vim
install_linux apt python-software-properties
install_linux apt python-pip
install_linux apt python3-pip
install_linux apt openssh-server
install_linux apt gitk
install_linux apt tmux
install_linux apt xclip
install_linux apt logkeys

# browsers
install_linux apt libindicator7
install_linux apt libappindicator1
install_linux deb google-chrome-stable "https://dl.google.com/linux/direct/google-chrome-stable_current_amd64.deb"

# sublime
install_linux deb sublime "https://download.sublimetext.com/sublime-text_build-3114_amd64.deb"

############################# customize tools #############################

pause "Configuring tools & scripts. Press [Enter] to continue..."

# bash config
git clone https://github.com/exklamationmark/dotfiles.git /tmp/dotfiles
cp -f /tmp/dotfiles/.bashrc ~/.bashrc
cp -f /tmp/dotfiles/.bash_aliases ~/.bash_aliases

# add xclip helper functions
cat /tmp/dotfiles/.bash_xclip >> ~/.bash_aliases

# define a custom prompt that shows more info on git repository
cat /tmp/dotfiles/.bash_custom_prompt >> ~/.bashrc

# customize vim
# vundle
git clone https://github.com/VundleVim/Vundle.vim.git ~/.vim/bundle/Vundle.vim
# minimum .vimrc
cp -f /tmp/dotfiles/.vimrc.vundle ~/.vimrc # basic vundle only
# install solarized color theme
vim +'PluginInstall altercation/vim-colors-solarized' +qall
# install golang plugin for vim
vim +'PluginInstall fatih/vim-go' +qall
# install dockerfile plugin for vim
vim +'PluginInstall ekalinin/Dockerfile.vim' +qall
# minimum .vimrc
cp -f /tmp/dotfiles/.vimrc ~/.vimrc # vundle + plugins + settings
# use solarized gnome (terminal)
git clone git://github.com/Anthony25/gnome-terminal-colors-solarized.git /tmp/gnome-terminal-colors-solarized
/tmp/gnome-terminal-colors-solarized/set_dark.sh

# tmux config
cp /tmp/dotfiles/.tmux.conf /home/mark/.tmux.conf

# git config
cp -f /tmp/dotfiles/.gitconfig ~/.gitconfig

# coding environment
if [[ -d "~/workspace" ]]
then
	mkdir -p ~/workspace
fi

############################# development things #############################

# ----------------------------- go (1.6.2) -----------------------------
sudo rm -rf /usr/local/go
curl 'https://storage.googleapis.com/golang/go1.6.2.linux-amd64.tar.gz' > /tmp/golang.tar.gz
sudo tar -C /usr/local/ -xzvf /tmp/golang.tar.gz
sudo ln -sf /usr/local/go/bin/go /usr/local/bin/go
# tool for dependency management
go get github.com/tools/godep
# linter
go get github.com/golang/lint/golint
# go env variables
cp -f /tmp/dotfiles/.bash_golang ~/.bash_golang
source ~/.bashrc

# ----------------------------- docker -----------------------------
install_linux apt docker.io
USER=`whoami`
sudo usermod -aG docker $USER
sudo ln -sf /usr/bin/docker.io /usr/local/bin/docker

# ----------------------------- postgresql -----------------------------
echo "deb http://apt.postgresql.org/pub/repos/apt/ trusty-pgdg main" > \
      sudo /etc/apt/sources.list.d/pgdg.list
wget -O - https://www.postgresql.org/media/keys/ACCC4CF8.asc | sudo apt-key add -
sudo apt-get update
install_linux apt postgresql-server-dev-9.5

# ----------------------------- redis -----------------------------
install_linux apt redis-server apt

# ----------------------------- rabbitmq -----------------------------
install_linux apt rabbitmq-server apt
sudo rabbitmq-plugins enable rabbitmq_management
sudo service rabbitmq-server restart

# ----------------------------- ruby -----------------------------
gpg --keyserver hkp://keys.gnupg.net --recv-keys 409B6B1796C275462A1703113804BB82D39DC0E3
curl -sSL https://get.rvm.io | bash
# progress bar for gem download
echo progress-bar >> ~/.curlrc
echo "gem: --no-rdoc --no-ri " >> ~/.gemrc

# ----------------------------- nodejs -----------------------------
curl -sL https://deb.nodesource.com/setup_6.x | sudo -E bash -
install_linux apt nodejs
mkdir -p $HOME/npm
npm config set prefix $HOME/npm
echo 'export PATH=$PATH:$HOME/npm/bin' >> ~/.bashrc
# nodejs env variables 
cp -f /tmp/dotfiles/.bash_nodejs ~/.bash_golang
source ~/.bashrc

# ############################# work-related helpers #############################
cat /tmp/dotfiles/.bash_viki >> ~/.bash_aliases
# 
# ############################# others #############################
# # ----------------------------- spotify -----------------------------
# # sudo bash -c "echo 'deb http://repository.spotify.com stable non-free' >> /etc/apt/sources.list.d/spotify.list"
# # sudo apt-key adv --keyserver keyserver.ubuntu.com --recv-keys 94558F59 && sudo apt-get update
# # install_linux apt spotify-client
# 
# ############################# key mapping #############################
# install_linux apt gnome-tweak-tool
# # open it, make Caps Lock an additional control in the Typing section
# 
# ############################# post-install #############################
docker login

############################# clean up #############################
echo -e $COLOR_BLUE"To get things started correctly, you might wanna do "$COLOR_RED"source ~/.bashrc"$COLOR_NONE" or start a new terminal session"
