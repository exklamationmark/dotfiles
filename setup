# install_linux apt hipchat

############################# others #############################
# ----------------------------- spotify -----------------------------
# sudo bash -c "echo 'deb http://repository.spotify.com stable non-free' >> /etc/apt/sources.list.d/spotify.list"
# sudo apt-key adv --keyserver keyserver.ubuntu.com --recv-keys 94558F59 && sudo apt-get update
# install_linux apt spotify-client
 
############################# finshing #############################
source ~/.bashrc

# clean up
rm -rf ~/.temp
