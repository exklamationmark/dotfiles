#! /bin/bash
# ---------------------- Viki related stuff ---------------------------
# quick db access
connect_postgres_db(){
  HOST=$1
  USER=$2
  PORT=$3
  DB=$4
  PG_PASSFILE=$5

  if [[ -n $PG_PASSFILE ]]
  then
    PGPASSFILE=$PG_PASSFILE psql -h $HOST -U $USER -p $PORT -d $DB
  else
    psql -h $HOST -U $USER -p $PORT -d $DB
  fi
}

prod.slave() {
  connect_postgres_db
}

