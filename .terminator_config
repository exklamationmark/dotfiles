[global_config]
  focus = mouse
  title_transmit_fg_color = "#002b36"
  title_inactive_fg_color = "#fdf6e3"
  title_receive_bg_color = "#268bd2"
  title_transmit_bg_color = "#fdf6e3"
  title_inactive_bg_color = "#657b83"
[keybindings]
[profiles]
